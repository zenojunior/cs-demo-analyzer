node_modules
dist
.turbo
*.log
.DS_Store
.env
.env.local
.vite
*.tsbuildinfo

# WSL artifacts (created when bringing files over from Windows)
*:Zone.Identifier

# CS2 demos (large input files, parsed in the browser).
# Covers both the raw .dem and the compressed containers accepted on upload.
*.dem
*.zst
*.dem.gz
*.dem.bz2

# libzstd wasm copied from @bokuweb/zstd-wasm into public/ by
# scripts/sync-zstd-wasm.mjs in the predev/prebuild hooks (generated artifact).
# Both the web app and the extension regenerate it locally.
/apps/app/public/zstd.wasm
/apps/extension/public/zstd.wasm

# Rust: WASM crate build artifacts (regenerated by build.sh).
# The .wasm consumed by the app is committed under apps/app/src/viewer/parser/.
/packages/parser/target/
